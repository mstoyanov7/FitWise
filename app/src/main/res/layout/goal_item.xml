<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="6dp"
    card_view:cardElevation="0dp"
    card_view:cardUseCompatPadding="true"
    android:layout_margin="8dp"
    card_view:cardBackgroundColor="#F4F4F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Left side: Goal title + date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGoalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drink 100l of Water"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvGoalDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04/05/2025"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Right side: dynamic “Undo” or “Complete” button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoalAction"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Undo"
            android:textAllCaps="false"
            android:layout_marginStart="16dp"
            android:textColor="#6B7280"
            android:backgroundTint="@color/light_gray"
            app:cornerRadius="8dp"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
