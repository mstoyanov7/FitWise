<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <solid android:color="@android:color/white" />

    <corners android:radius="100dp" />

    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />

    <size
        android:width="120dp"
        android:height="120dp" />

    <stroke
        android:width="1dp"
        android:color="#CCCCCC" />
</shape>
