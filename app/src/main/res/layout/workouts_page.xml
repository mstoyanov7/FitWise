<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:scrollbars="none"
        android:layout_above="@id/bottom_navigation">

        <LinearLayout
            android:id="@+id/all_exercises_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Page Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="50dp"
                android:text="Exercises"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/open_sans_bold" />

            <!-- Filter Buttons -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_strength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strength"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cardio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cardio"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_calisthenics"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calisthenics"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_running"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Running"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_yoga"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yoga"
                        android:textAllCaps="false"
                        android:textColor="@color/category_button_text"
                        app:backgroundTint="@color/category_button_bg"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="8dp"
                        app:checkedIcon="@null"
                        android:checkable="true"
                        app:fontFamily="@font/open_sans_regular" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Search -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/search_bar_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/search_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_search"
                    app:tint="#888888" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/search_icon"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="Search exercises"
                    android:inputType="text"
                    android:textSize="14dp"
                    android:textColor="#000000"
                    android:textColorHint="#888888"
                    android:fontFamily="@font/open_sans_regular" />
            </RelativeLayout>

            <!-- Favorite Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:id="@+id/favorites_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/favorite_toggle_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Favorite Exercises"
                        android:textSize="18sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:fontFamily="@font/open_sans_bold" />

                    <ImageView
                        android:id="@+id/favorite_toggle_arrow"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="18dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="#898989" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/favorite_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- All Exercises -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Exercises"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/open_sans_bold" />

            <LinearLayout
                android:id="@+id/exercises_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F4F4F5"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />
</RelativeLayout>
