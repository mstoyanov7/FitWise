<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/constraint_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scanned_food"
            android:textSize="26sp"
            android:fontFamily="@font/open_sans_bold"
            android:layout_marginTop="60dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_heart"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_empty_placeholder" />
    </RelativeLayout>

    <!-- Food Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_food_details"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="0dp"
        app:strokeColor="#797979"
        app:strokeWidth="0.5dp"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Circular Food Image -->
            <ImageView
                android:id="@+id/iv_food"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_empty_placeholder"
                android:scaleType="centerCrop"
                android:background="@drawable/circular_bg"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Food Name -->
            <TextView
                android:id="@+id/tv_food_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/healthy_food"
                android:textSize="18sp"
                android:fontFamily="@font/open_sans_bold"
                android:textColor="@color/black"

                app:layout_constraintTop_toTopOf="@id/iv_food"
                app:layout_constraintStart_toEndOf="@id/iv_food"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="12dp"/>

            <!-- Food Summary (kcal, weight, protein) -->
            <TextView
                android:id="@+id/tv_food_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/food_summary"
                android:textSize="14sp"
                android:fontFamily="@font/open_sans_regular"
                android:textColor="@color/dark_gray"
                app:layout_constraintTop_toBottomOf="@id/tv_food_name"
                app:layout_constraintStart_toStartOf="@id/tv_food_name"
                app:layout_constraintEnd_toEndOf="@id/tv_food_name"
                android:layout_marginTop="4dp"/>

            <!-- Stats Row within Card -->
            <LinearLayout
                android:id="@+id/ll_stats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/iv_food"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:weightSum="3">

                <!-- Calories -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tv_stat_calories_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calories_value"
                        android:textSize="18sp"
                        android:fontFamily="@font/open_sans_bold"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_calories_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:fontFamily="@font/open_sans_regular"
                        android:textColor="#898989"
                        android:text="@string/kcal"
                        android:textAppearance="@style/TextAppearance.AppCompat.Small" />
                </LinearLayout>

                <!-- Weight -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_bg"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">

                    <!-- Editable grams input -->
                    <EditText
                        android:id="@+id/tv_stat_weight_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quantity_value"
                        android:textSize="18sp"
                        android:fontFamily="@font/open_sans_bold"
                        android:inputType="number"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:cursorVisible="true"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:imeOptions="actionDone"
                        android:maxLength="4"/>

                    <TextView
                        android:id="@+id/tv_weight_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/open_sans_regular"
                        android:textColor="#898989"
                        android:text="@string/grams"
                        android:textAppearance="@style/TextAppearance.AppCompat.Small" />
                </LinearLayout>
                <!-- Protein -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tv_stat_protein_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/protein_value"
                        android:textSize="18sp"
                        android:fontFamily="@font/open_sans_bold"
                        />
                    <TextView
                        android:id="@+id/tv_protein_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/open_sans_regular"
                        android:textColor="#898989"
                        android:text="@string/protein"
                        android:textAppearance="@style/TextAppearance.AppCompat.Small" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Tab Layout for Switching between Nutritional Values and Ingredients -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_border"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabSelectedTextColor="@color/colorPrimary"

        android:fontFamily="@font/open_sans_bold"
        app:layout_constraintTop_toBottomOf="@id/card_food_details"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"/>

    <!-- Detailed Nutritional Info List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_details"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/button_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_layout" />

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_new_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_again"
            android:textColor="@android:color/white"
            android:fontFamily="@font/open_sans_semibold"
            android:backgroundTint="@color/colorPrimary"
            android:minWidth="140dp"
            android:paddingHorizontal="12dp" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btn_add_diary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_food"
            android:textColor="@android:color/white"
            android:fontFamily="@font/open_sans_semibold"
            android:backgroundTint="@color/colorPrimary"
            android:minWidth="140dp"
            android:paddingHorizontal="12dp" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
