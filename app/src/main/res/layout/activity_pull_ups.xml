<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/pull_ups_ex_background" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/workout_list_container"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Title -->
            <TextView
                android:id="@+id/title"
                android:text="Pull-Ups"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_marginTop="150dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Buttons -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageButton
                    android:id="@+id/search_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button"
                    android:padding="13dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_search"
                    app:tint="@color/white"
                    android:contentDescription="@string/search_button" />

                <ImageButton
                    android:id="@+id/infoBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button"
                    android:padding="13dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/info"
                    android:contentDescription="@string/info_button_description"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- Search input (hidden by default) -->
            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search workouts..."
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="@drawable/search_field_bg"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:inputType="text" />

            <!-- Workout card example -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_card_bg_pull_ups_ex"
                android:padding="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pull"
                    android:background="@drawable/image_rounded_bg_pull_ups_ex"
                    android:clipToOutline="true" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/workout_title_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pull-Ups"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workout 3x3"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Superset, 40min"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_heart"
                    app:tint="#00C37A" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_card_bg_pull_ups_ex"
                android:padding="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pull"
                    android:background="@drawable/image_rounded_bg_pull_ups_ex"
                    android:clipToOutline="true" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/workout_title_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pull-Ups"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workout 3x3"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#000000" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Superset, 40min"
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_heart"
                    app:tint="#00C37A" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
