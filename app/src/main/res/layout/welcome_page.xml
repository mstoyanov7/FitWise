<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@drawable/dips"
        android:contentDescription="Header Image" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/register_form_container"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textSize="23sp"
                android:textStyle="bold"
                android:textColor="#076653"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="15dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tell us more about you"
                android:textSize="18sp"
                android:textColor="#3D3A37"
                android:layout_marginStart="15dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/form_inner_box"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_horizontal">

                <!-- Avatar Upload -->
                <ImageView
                    android:id="@+id/avatarImageView"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/avatar"
                    android:background="@drawable/circle_white_shadow"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:layout_marginBottom="20dp"
                    android:contentDescription="User Avatar" />

                <!-- Weight -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="#E6F2EA"
                    app:boxCornerRadiusTopStart="6dp"
                    app:boxCornerRadiusTopEnd="6dp"
                    app:boxCornerRadiusBottomStart="6dp"
                    app:boxCornerRadiusBottomEnd="6dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/weightEditText"
                        android:hint="Current Weight (kg)"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Age -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="#E6F2EA"
                    app:boxCornerRadiusTopStart="6dp"
                    app:boxCornerRadiusTopEnd="6dp"
                    app:boxCornerRadiusBottomStart="6dp"
                    app:boxCornerRadiusBottomEnd="6dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/ageEditText"
                        android:hint="Age"
                        android:inputType="number"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sex -->
                <RadioGroup
                    android:id="@+id/sexRadioGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <RadioButton
                        android:id="@+id/maleRadio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Male"
                        android:textColor="@color/black" />

                    <RadioButton
                        android:id="@+id/femaleRadio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Female"
                        android:textColor="@color/black"
                        android:layout_marginStart="20dp" />
                </RadioGroup>

                <!-- Daily Activity Level -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How do you describe yourself?"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="6dp"
                    android:layout_gravity="start" />

                <Spinner
                    android:id="@+id/activityLevelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" />

                <!-- Goal Weight -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxBackgroundMode="filled"
                    app:boxBackgroundColor="#E6F2EA"
                    app:boxCornerRadiusTopStart="6dp"
                    app:boxCornerRadiusTopEnd="6dp"
                    app:boxCornerRadiusBottomStart="6dp"
                    app:boxCornerRadiusBottomEnd="6dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/goalWeightEditText"
                        android:hint="Goal Weight (kg)"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Weekly Goal -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly Goal"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="6dp"
                    android:layout_gravity="start" />

                <Spinner
                    android:id="@+id/weeklyGoalSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp" />

                <!-- Submit Button -->
                <Button
                    android:id="@+id/finishButton"
                    android:text="Continue"
                    android:layout_width="230dp"
                    android:layout_height="53dp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="23sp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#076653" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
